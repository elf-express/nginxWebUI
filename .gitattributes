# 預設：所有文字檔工作區與倉庫都用 LF（避免 Windows 自動 LF→CRLF）
* text=auto eol=lf

# 明確列出常見文字檔，全部 LF
*.java        text eol=lf
*.js          text eol=lf
*.ts          text eol=lf
*.json        text eol=lf
*.html        text eol=lf
*.ftl         text eol=lf
*.css         text eol=lf
*.scss        text eol=lf
*.xml         text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.md          text eol=lf
*.properties  text eol=lf
*.sql         text eol=lf
*.conf        text eol=lf
*.svg         text eol=lf

# Shell scripts 必須 LF（CLAUDE.md：entrypoint.sh 必須 LF 換行）
*.sh          text eol=lf
entrypoint.sh text eol=lf
Dockerfile    text eol=lf
.dockerignore text eol=lf
.gitignore    text eol=lf
.gitattributes text eol=lf

# Windows 專用腳本維持 CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# ---- GitHub Linguist 語言統計標記 ----
# 排除第三方 vendored libs（zTree/CodeMirror/Layui 等），避免 340+ HTML 蓋掉 Java/JS 比例
src/main/resources/static/lib/**       linguist-vendored=true
# 專案內文件目錄，算文件不算 code
src/main/resources/static/doc/**       linguist-documentation=true
# 測試 artifacts（本地產物，一般已 gitignore；雙保險）
tests/playwright-report/**             linguist-generated=true

# 二進位檔：明確標 binary 避免任何換行處理
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.webp        binary
*.woff        binary
*.woff2       binary
*.ttf         binary
*.eot         binary
*.otf         binary
*.jar         binary
*.zip         binary
*.gz          binary
*.tar         binary
*.7z          binary
*.pdf         binary
*.mp4         binary
*.mp3         binary
*.db          binary
*.sqlite      binary
