{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Requests / min",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*2\\d{2}.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*3\\d{2}.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*4\\d{2}.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*5\\d{2}.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "sum by (status) (count_over_time({job=\"nginx\", type=\"access\"} | regexp `\"(?P<method>\\w+) (?P<request>[^ ]+) [^\"]+\" (?P<status>\\d+)` [1m]))",
          "legendFormat": "{{status}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Requests by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "200" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "301" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "302" },
            "properties": [{ "id": "color", "value": { "fixedColor": "super-light-blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "404" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "500" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "options": {
        "displayLabels": ["percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "sum by (status) (count_over_time({job=\"nginx\", type=\"access\"} | regexp `\"(?P<method>\\w+) (?P<request>[^ ]+) [^\"]+\" (?P<status>\\d+)` [$__range]))",
          "legendFormat": "{{status}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Status Code Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Request Details",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Requests / min",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "group": "A", "mode": "none" }
          }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "sum by (method) (count_over_time({job=\"nginx\", type=\"access\"} | regexp `\"(?P<method>\\w+) ` [1m]))",
          "legendFormat": "{{method}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Requests by Method",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "Requests / min",
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"nginx\", type=\"access\"} [1m]))",
          "legendFormat": "Total Requests",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Total Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "displayName", "value": "Count" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "request" },
            "properties": [{ "id": "displayName", "value": "Path" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "topk(20, sum by (request) (count_over_time({job=\"nginx\", type=\"access\"} | regexp `\"\\w+ (?P<request>[^ ]+) ` [$__range])))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 20 Requested Paths",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "displayName", "value": "Count" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "remote_addr" },
            "properties": [{ "id": "displayName", "value": "Client IP" }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "topk(20, sum by (remote_addr) (count_over_time({job=\"nginx\", type=\"access\"} | regexp `^(?P<remote_addr>[\\w\\.]+) ` [$__range])))",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 20 Client IPs",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Error Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 27 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "editorMode": "code",
          "expr": "{job=\"nginx\", type=\"access\"} |= `` | regexp `\"(?P<method>\\w+) (?P<request>[^ ]+) [^\"]+\" (?P<status>\\d+)` | status >= 400",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "4xx / 5xx Error Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 34 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
