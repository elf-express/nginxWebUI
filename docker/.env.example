# ============================================
# Nginx Web UI 部署環境設定
# ============================================
# 使用方式：
#   1. 複製此檔案為 .env：cp .env.example .env
#   2. 填入下方金鑰
#   3. 啟動：docker compose up -d
# ============================================

# nginxwebui image 版本（留空 = latest）
# → 釘到指定版本：NGINX_WEBUI_VERSION=x.y.z
# → 用 latest 自動跟最新 release（不可重現）：NGINX_WEBUI_VERSION=latest
# → 從原始碼本機 build：docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
NGINX_WEBUI_VERSION=latest

# 要啟用的可選服務（預設只起 nginxwebui + postgres）
# → 監控（Loki/Promtail/Grafana）：COMPOSE_PROFILES=monitoring
# → 安全（CrowdSec + bouncer）：COMPOSE_PROFILES=monitoring,security
# 留空 = 只起核心。也可改用 `docker compose --profile monitoring up -d`。
COMPOSE_PROFILES=

# 初始管理員（選用 — 預設不設，讓首次啟動的 web UI 引導你設密碼）
# 若用於自動化部署需跳過 UI 精靈，取消下兩行註解並填入帳密，並在
# docker-compose.yml 的 BOOT_OPTIONS 加回 --init.admin=${INIT_ADMIN}
# --init.pass=${INIT_PASS} 兩個參數。
# INIT_ADMIN=admin
# INIT_PASS=ChangeThisToAStrongPassword

# https://www.crowdsec.net/
# CrowdSec Bouncer 金鑰
# → 首次部署先填任意值啟動，啟動後執行以下指令取得真正金鑰：
#   docker exec nginxwebui-crowdsec cscli bouncers add nginx
# → 把輸出的金鑰貼到這裡，然後重啟 bouncer：
#   docker compose restart crowdsec-bouncer
CROWDSEC_BOUNCER_KEY=your-bouncer-key-here

# AbuseIPDB API 金鑰
# → 到 https://www.abuseipdb.com 註冊帳號
# → 登入後到 Account → API Keys → Create Key
# → 把金鑰貼到這裡
ABUSEIPDB_API_KEY=your-api-key-here
